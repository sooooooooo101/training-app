# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Function (採点処理)
VITE_SUBMIT_QUIZ_URL=https://your-project.supabase.co/functions/v1/submit-quiz

